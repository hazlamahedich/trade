{
  "ci": {
    "collect": {
      "url": ["http://localhost:3002/"],
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 1080 }, "error", { "maxNumericValue": 1200 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.09 }, "error", { "maxNumericValue": 0.1 }],
        "first-input-delay": ["warn", { "maxNumericValue": 90 }, "error", { "maxNumericValue": 100 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 180 }, "error", { "maxNumericValue": 200 }],
        "interactive": ["warn", { "maxNumericValue": 2250 }, "error", { "maxNumericValue": 2500 }]
      }
    }
  }
}
